# Port Render (or any PaaS) injects automatically; only needed for local overrides.
PORT=4000

# Restrict Socket.IO/CORS to your deployed frontend origin once you have it,
# e.g. https://your-app.vercel.app. Defaults to "*" (any origin) if unset.
CORS_ORIGIN=*

# Optional: set both to have the PR bot push a real branch and open a real
# GitHub PR instead of returning a dry-run preview.
GITHUB_TOKEN=
GITHUB_REPO=
