# Port Render (or any PaaS) injects automatically; only needed for local overrides.
PORT=4000

# Restrict Socket.IO/CORS to your deployed frontend origin once you have it,
# e.g. https://your-app.vercel.app. Defaults to "*" (any origin) if unset.
CORS_ORIGIN=*

# Optional: set both to have the PR bot push a real branch and open a real
# GitHub PR instead of returning a dry-run preview.
#
# GITHUB_REPO must be a DEDICATED repo (owner/repo) seeded/owned by the bot —
# NOT this app's own repo. The bot force-resets its local watched-repo/ clone
# to match that repo's `main` and force-pushes fix/* branches to it, so
# pointing it at a repo with unrelated content/history would get clobbered.
# On first run against a brand-new empty repo it seeds `main` automatically
# with the 3 demo files in backend/watched-repo/.
#
# GITHUB_TOKEN: a fine-grained PAT (github.com/settings/tokens) scoped to
# just that one repo, with Contents: Read/write + Pull requests: Read/write.
GITHUB_TOKEN=
GITHUB_REPO=owner/your-dedicated-demo-repo

# Optional: set all four to pull real Jira Cloud tickets instead of mock
# data, and to let create_ticket open real tickets (used by the log-incident
# pipeline below). JIRA_BASE_URL should be just the site root, e.g.
# https://yourcompany.atlassian.net (no path/query string). JIRA_API_TOKEN
# is created at id.atlassian.com/manage-profile/security/api-tokens.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
# Issue type to use when creating tickets — must exist in your project
# (simplified/next-gen projects often only have Task/Story/Epic, no Bug).
JIRA_ISSUE_TYPE=Task

# Optional: free-tier LLM key(s) for the log-incident-to-Jira-ticket pipeline
# to draft summary/description/priority. Without either, a deterministic
# rule-based draft is used instead — the pipeline still works, just without
# LLM-written wording. If both are set, Groq is tried first.
#
# Groq (console.groq.com, no card required):
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
#
# Gemini (aistudio.google.com) — note some Google Cloud-issued keys require
# billing to be enabled even for "free tier" quota; Groq avoids that gotcha:
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
